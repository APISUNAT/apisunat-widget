{
	"name": "invoice-sunat",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build --mode element",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"module": "./dist/sunat-invoice.js",
	"style": "./dist/assets/invoice-sunat.css",
	"type": "module",
	"exports": {
		".": {
			"default": "./dist/sunat-invoice.js"
		},
		"./styles.css": "./dist/assets/invoice-sunat.css"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.2.4",
		"autoprefixer": "^10.5.0",
		"postcss": "^8.5.10",
		"publint": "^0.3.18",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.0.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"preline": "^4.1.3"
	}

}
